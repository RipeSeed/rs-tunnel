{
  "name": "@ripeseed/rs-tunnel",
  "version": "0.1.4",
  "description": "CLI for running secure public tunnels to localhost through Cloudflare.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RipeSeed/rs-tunnel.git",
    "directory": "apps/cli"
  },
  "bugs": {
    "url": "https://github.com/RipeSeed/rs-tunnel/issues"
  },
  "homepage": "https://github.com/RipeSeed/rs-tunnel/tree/main/apps/cli",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "rs-tunnel": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "pnpm --filter @ripeseed/shared build && tsx watch src/index.ts",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "format": "prettier --check src"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "dependencies": {
    "@ripeseed/shared": "workspace:*",
    "commander": "^13.1.0",
    "open": "^10.1.0",
    "zod": "^3.24.1"
  },
  "optionalDependencies": {
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "@ripeseed/config": "workspace:*",
    "@types/node": "^22.12.0",
    "tsx": "^4.19.2",
    "vitest": "^3.0.5"
  }
}
